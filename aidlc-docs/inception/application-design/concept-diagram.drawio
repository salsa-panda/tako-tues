        </mxCell>

        <!-- A: タコスを食べる -->
        <mxCell id="v-a" value="&lt;b&gt;タコスを食べる&lt;/b&gt;&#xa;消費量 N ↑" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="50" y="140" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- B: タコスを食べない -->
        <mxCell id="v-b" value="&lt;b&gt;タコスを食べない&lt;/b&gt;&#xa;消費量 N ↓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="50" y="340" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- R1: 来週は少なめ -->
